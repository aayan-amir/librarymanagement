  "components": {
    "schemas": {
      "BorrowedBookDto": {
        "required": [
          "transactionId",
          "title",
          "author",
          "accessionNo",
          "issuedAt",
          "dueAt",
          "status"
        ],
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "accessionNo": {
            "type": "string"
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time"
          },
          "dueAt": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "BorrowedBooksResponse": {
        "required": [
          "universityId",
          "activeBorrowCount",
          "books"
        ],
        "type": "object",
        "properties": {
          "universityId": {
            "type": "string"
          },
          "activeBorrowCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "borrowLimit": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "books": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BorrowedBookDto"
            }
          }
        }
      },
      "IssueBookRequest": {
        "required": [
          "universityId",
          "qrCodeId"
        ],
        "type": "object",
        "properties": {
          "universityId": {
            "maxLength": 30,
            "minLength": 4,
            "type": "string"
          },
          "qrCodeId": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "IssueBookResponse": {
        "required": [
          "success",
          "statusCode",
          "message"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "transactionId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "statusCode": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "issuedAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "dueAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "serverTimeUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LoginStudentRequest": {
        "required": [
          "universityId",
          "password"
        ],
        "type": "object",
        "properties": {
          "universityId": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "LoginStudentResponse": {
        "required": [
          "success",
          "statusCode",
          "message"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "statusCode": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "universityId": {
            "type": [
              "null",
              "string"
            ]
          },
          "fullName": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RegisterStudentRequest": {
        "required": [
          "universityId",
          "fullName",
          "email",
          "password",
          "departmentCode",
          "semester"
        ],
        "type": "object",
        "properties": {
          "universityId": {
            "maxLength": 30,
            "minLength": 4,
            "type": "string"
          },
          "fullName": {
            "maxLength": 150,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "departmentCode": {
            "type": "string"
          },
          "semester": {
            "maximum": 8,
            "minimum": 1,
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "RegisterStudentResponse": {
        "required": [
          "success",
          "statusCode",
          "message"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "statusCode": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "TransactionHistoryDto": {
        "required": [
          "transactionId",
          "title",
          "author",
          "accessionNo",
          "transactionType",
          "status",
          "issuedAt",
          "dueAt"
        ],
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "accessionNo": {
            "type": "string"
          },
          "transactionType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time"
          },
          "dueAt": {
            "type": "string",
            "format": "date-time"
          },
          "returnedAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "TransactionHistoryResponse": {
        "required": [
          "universityId",
          "transactions"
        ],
        "type": "object",
        "properties": {
          "universityId": {
            "type": "string"
          },
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransactionHistoryDto"
            }
          }
        }
      }
    }
  },
