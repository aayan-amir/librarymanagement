  "components": {
    "schemas": {
      "ActivityLogDto": {
        "required": [
          "activityLogId",
          "actionType",
          "actionStatus",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "activityLogId": {
            "type": "string",
            "format": "uuid"
          },
          "actorUniversityId": {
            "type": [
              "null",
              "string"
            ]
          },
          "actorRole": {
            "type": [
              "null",
              "string"
            ]
          },
          "actionType": {
            "type": "string"
          },
          "actionStatus": {
            "type": "string"
          },
          "endpoint": {
            "type": [
              "null",
              "string"
            ]
          },
          "failureReason": {
            "type": [
              "null",
              "string"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ActivityLogsResponse": {
        "required": [
          "logs",
          "totalCount"
        ],
        "type": "object",
        "properties": {
          "logs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActivityLogDto"
            }
          },
          "totalCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "AdminDashboardResponse": {
        "required": [
          "totalIssuedBooks",
          "overdueBooks",
          "activeBorrowers",
          "activeInventory",
          "outstandingFines",
          "fineCollectionTotal"
        ],
        "type": "object",
        "properties": {
          "totalIssuedBooks": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "overdueBooks": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "activeBorrowers": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "activeInventory": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "outstandingFines": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "fineCollectionTotal": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "AnalyticsDashboardResponse": {
        "required": [
          "mostActiveStudents",
          "popularBooks",
          "peakIssuingTimings",
          "fineTrends",
          "departmentWiseStatistics",
          "defaultersList",
          "dailyTransactions"
        ],
        "type": "object",
        "properties": {
          "mostActiveStudents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DashboardListItemDto"
            }
          },
          "popularBooks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DashboardListItemDto"
            }
          },
          "peakIssuingTimings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DashboardListItemDto"
            }
          },
          "fineTrends": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DashboardListItemDto"
            }
          },
          "departmentWiseStatistics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DashboardListItemDto"
            }
          },
          "defaultersList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DashboardListItemDto"
            }
          },
          "dailyTransactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DashboardListItemDto"
            }
          }
        }
      },
      "BorrowedBookDto": {
        "required": [
          "transactionId",
          "title",
          "author",
          "accessionNo",
          "issuedAt",
          "dueAt",
          "status"
        ],
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "accessionNo": {
            "type": "string"
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time"
          },
          "dueAt": {
